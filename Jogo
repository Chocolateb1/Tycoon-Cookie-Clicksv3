<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Cookie Empire Tycoon V27</title>
    <style>
        :root { --primary: #00ff88; --bg: #0a0a0b; --surface: #16161a; --gold: #ffd700; }
        * { -webkit-tap-highlight-color: transparent; user-select: none; box-sizing: border-box; outline: none; }
        body { margin: 0; background: var(--bg); color: white; font-family: 'Segoe UI', sans-serif; display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
        #header { text-align: center; padding: 15px; background: var(--surface); border-bottom: 2px solid #333; }
        #dinheiro { font-size: 32px; font-weight: 900; color: var(--primary); text-shadow: 0 0 10px rgba(0,255,136,0.4); }
        #stats-bar { font-size: 11px; color: #888; margin-top: 5px; text-transform: uppercase; }
        #tabs { display: flex; background: #000; }
        .tab-btn { flex: 1; padding: 15px; border: none; background: none; color: #555; font-weight: bold; }
        .tab-btn.active { color: var(--primary); border-bottom: 3px solid var(--primary); }
        #area-clique { flex-grow: 1; display: flex; align-items: center; justify-content: center; background: radial-gradient(circle, #2c1a0a 0%, #000 100%); }
        #cookie { width: 160px; height: 160px; background: radial-gradient(circle at 35% 35%, #e2a65a 0%, #b5651d 80%); border-radius: 50%; box-shadow: 0 10px 0 #5d2e0a, 0 20px 40px rgba(0,0,0,0.6); transition: transform 0.05s; cursor: pointer; }
        #cookie:active { transform: scale(0.92) translateY(5px); }
        #panel { height: 45vh; background: var(--surface); border-top: 2px solid #333; overflow-y: auto; }
        .content { padding: 10px; display: none; }
        .content.active { display: block; }
        .item { background: #1f1f25; margin-bottom: 8px; padding: 12px; border-radius: 12px; display: flex; justify-content: space-between; align-items: center; border: 1px solid #2d2d35; }
        .btn-buy { background: var(--primary); color: #000; border: none; padding: 10px; border-radius: 8px; font-weight: 800; min-width: 90px; }
        .btn-buy:disabled { opacity: 0.3; }
        .rank-item { display: flex; justify-content: space-between; padding: 12px; border-bottom: 1px solid #222; }
        .me { background: rgba(255, 215, 0, 0.1); color: var(--gold); font-weight: bold; }
    </style>
</head>
<body>
    <div id="header">
        <div id="dinheiro">$ 0</div>
        <div id="stats-bar">LUCRO: $ <span id="gps">0</span>/s</div>
    </div>
    <div id="tabs">
        <button class="tab-btn active" onclick="tab('loja', this)">LOJA (50)</button>
        <button class="tab-btn" onclick="tab('rank', this)">RANKING</button>
    </div>
    <div id="area-clique"><div id="cookie" onclick="clicar()"></div></div>
    <div id="panel">
        <div id="loja" class="content active"></div>
        <div id="rank" class="content"></div>
    </div>
    <script>
        let game = { dinheiro: 0, porClique: 1, porSegundo: 0, upgrades: [] };
        const nomes = ["Cursor", "Vovó", "Padaria", "Fábrica", "Mina", "Banco", "Templo", "Mago", "Portal", "Nave"];
        const adjs = ["Bronze", "Ferro", "Aço", "Ouro", "Platina"];

        for(let i=0; i<50; i++) {
            game.upgrades.push({
                id: i,
                nome: adjs[Math.floor(i/10)] + " " + nomes[i%10],
                preco: 15 * Math.pow(2.1, i),
                power: (i + 1) * Math.pow(2.4, i),
                tipo: i % 5 === 0 ? 'c' : 's',
                count: 0
            });
        }

        function format(v) { 
            if(v >= 1e9) return (v/1e9).toFixed(2)+"B";
            if(v >= 1e6) return (v/1e6).toFixed(2)+"M";
            return Math.floor(v).toLocaleString(); 
        }

        function clicar() { game.dinheiro += game.porClique; update(); }

        function comprar(id) {
            let u = game.upgrades[id];
            if(game.dinheiro >= u.preco) {
                game.dinheiro -= u.preco; u.count++;
                if(u.tipo === 'c') game.porClique += u.power; else game.porSegundo += u.power;
                u.preco *= 1.6; update();
            }
        }

        function tab(t, b) {
            document.querySelectorAll('.content, .tab-btn').forEach(e => e.classList.remove('active'));
            document.getElementById(t).classList.add('active'); b.classList.add('active');
            if(t === 'rank') {
                let r = document.getElementById('rank');
                r.innerHTML = "<h3 style='text-align:center'>RANKING GLOBAL</h3>";
                let lista = [{n:"Imperador", s:1e12}, {n:"Você", s:game.dinheiro, m:true}, {n:"Padeiro", s:500}];
                lista.sort((x,y) => y.s - x.s).forEach((p,i) => {
                    r.innerHTML += `<div class="rank-item ${p.m?'me':''}">#${i+1} ${p.n} <span>$ ${format(p.s)}</span></div>`;
                });
            }
        }

        function update() {
            document.getElementById('dinheiro').innerText = "$ " + format(game.dinheiro);
            document.getElementById('gps').innerText = format(game.porSegundo);
            let l = document.getElementById('loja'); l.innerHTML = "";
            game.upgrades.forEach(u => {
                l.innerHTML += `<div class="item"><div><b>${u.nome}</b><br><small>Qtd: ${u.count}</small></div>
                <button class="btn-buy" ${game.dinheiro < u.preco ? 'disabled' : ''} onclick="comprar(${u.id})">${format(u.preco)}</button></div>`;
            });
        }

        setInterval(() => { game.dinheiro += game.porSegundo/10; update(); }, 100);
        update();
    </script>
</body>
</html>
